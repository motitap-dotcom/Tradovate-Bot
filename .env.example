# Tradovate Credentials
# Copy this file to .env and fill in your values.
# NEVER commit the .env file.

# Username & password — required for both browser and API login
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password

# API credentials — only needed if you have a Tradovate API key
TRADOVATE_APP_ID=
TRADOVATE_CID=0
TRADOVATE_SECRET=
TRADOVATE_DEVICE_ID=tradovate-bot-001

# Manual token — paste from browser DevTools to skip CAPTCHA (one-time).
# Steps: Log in at trader.tradovate.com → F12 → Application →
# Local Storage → look for accessToken value → paste here.
# After first run, the bot saves and auto-renews the token.
TRADOVATE_ACCESS_TOKEN=

# Environment: "demo" or "live"
TRADOVATE_ENV=demo

# Prop firm: "apex", "topstep", or "fundednext"
PROP_FIRM=fundednext

# Tradovate organization (auto-set from PROP_FIRM if empty)
# FundedNext uses empty string — do NOT set to "funded-next"
TRADOVATE_ORGANIZATION=

# Logging
LOG_LEVEL=INFO
LOG_FILE=bot.log
