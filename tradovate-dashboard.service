[Unit]
Description=Tradovate Dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=/root/Tradovate-Bot
ExecStart=/usr/bin/python3 /root/Tradovate-Bot/dashboard.py
Restart=always
RestartSec=10
StandardOutput=append:/root/Tradovate-Bot/dashboard.log
StandardError=append:/root/Tradovate-Bot/dashboard.log
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
